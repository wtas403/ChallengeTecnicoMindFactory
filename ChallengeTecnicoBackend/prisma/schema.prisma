generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Sujeto {
  id             Int         @id @default(autoincrement())
  cuit           String      @unique @db.VarChar(11)
  nombreCompleto String      @db.VarChar(120)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  automotores    Automotor[]
}

model Automotor {
  id                Int      @id @default(autoincrement())
  dominio           String   @unique @db.VarChar(7)
  chasis            String   @unique @db.VarChar(50)
  motor             String   @unique @db.VarChar(50)
  color             String   @db.VarChar(50)
  fechaFabricacion  String   @db.VarChar(6)
  sujetoId          Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sujeto            Sujeto   @relation(fields: [sujetoId], references: [id], onDelete: Restrict)

  @@index([sujetoId])
}

model WebVitalMetric {
  id             Int      @id @default(autoincrement())
  metric         String   @db.VarChar(10)
  value          Float
  delta          Float
  rating         String   @db.VarChar(32)
  metricId       String   @db.VarChar(128)
  pageId         String   @db.VarChar(255)
  url            String   @db.VarChar(2048)
  navigationType String   @db.VarChar(64)
  sessionId      String   @db.VarChar(64)
  userAgent      String   @db.VarChar(512)
  appVersion     String   @db.VarChar(32)
  occurredAt     DateTime
  createdAt      DateTime @default(now())

  @@index([metric, pageId, occurredAt])
  @@index([sessionId, occurredAt])
}
